# Copy this file to: scripts/macos/launch-assistant.profile
# The Launch Assistant auto-loads this file when present.

# Optional: local repo path on your Mac
# export THORPE_REPO_PATH="$HOME/Thorpe-Workforce"

# Environment + support
export THORPE_ENVIRONMENT="production"
export THORPE_SUPPORT_EMAIL="support@thorpeworkforce.ai"

# Production domains
export THORPE_FRONTEND_URL="https://thorpeworkforce.ai"
export THORPE_API_URL="https://api-thorpeworkforce.com"

# Staging domains
export THORPE_STAGING_FRONTEND_URL="https://staging.thorpeworkforce.ai"
export THORPE_STAGING_API_URL="https://staging-api.thorpeworkforce.ai"

# Dashboard shortcuts
export THORPE_RAILWAY_DASHBOARD_URL="https://railway.app"
export THORPE_VERCEL_DASHBOARD_URL="https://vercel.com/dashboard"
export THORPE_STRIPE_DASHBOARD_URL="https://dashboard.stripe.com"
export THORPE_GITHUB_REPO_URL="https://github.com/jonniethorpe45-max/Thorpe-Workforce"

# IONOS DNS helper defaults (used by Launch Assistant menu options 13-15)
export THORPE_IONOS_ZONE_DOMAIN="thorpeworkforce.ai"
export THORPE_RAILWAY_API_CNAME_TARGET="REPLACE_WITH_PROD_RAILWAY_DOMAIN.up.railway.app"
export THORPE_RAILWAY_STAGING_API_CNAME_TARGET="REPLACE_WITH_STAGING_RAILWAY_DOMAIN.up.railway.app"
export THORPE_VERCEL_CNAME_TARGET="cname.vercel-dns.com"
export THORPE_VERCEL_APEX_A_TARGET="76.76.21.21"
export THORPE_DNS_DEFAULT_TTL="3600"

# Stripe helper defaults (menu options 13-16)
export THORPE_STRIPE_MODE="test"
export THORPE_STRIPE_SECRET_KEY=""
export THORPE_STRIPE_PUBLISHABLE_KEY=""
export THORPE_STRIPE_WEBHOOK_SECRET=""
export THORPE_STRIPE_PRICE_ID_PRO_MONTHLY=""
export THORPE_STRIPE_PRICE_ID_PRO_ANNUAL=""
export THORPE_STRIPE_PRICE_ID_CREATOR_MONTHLY=""
export THORPE_STRIPE_PRICE_ID_CREATOR_ANNUAL=""
export THORPE_STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=""
export THORPE_STRIPE_BILLING_PORTAL_RETURN_URL="https://thorpeworkforce.ai/app/settings/billing"
