{
  "install": "bash .cursor/scripts/install_fullstack_env.sh",
  "start": "bash .cursor/scripts/start_fullstack_env.sh",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "NPM_CONFIG_FUND": "false",
    "NPM_CONFIG_AUDIT": "false",
    "RUN_SMOKE_CHECKS_ON_START": "true"
  }
}
