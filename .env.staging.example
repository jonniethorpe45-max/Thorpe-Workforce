ENVIRONMENT=staging

# Backend required
SECRET_KEY=replace-with-long-random-staging-secret
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/thorpe_workforce_staging
REDIS_URL=redis://redis:6379/0
APP_BASE_URL=https://staging.example.com
SUPPORT_EMAIL=support@example.com

# Backend optional integrations (use staging/test keys)
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_test_replace
SENDGRID_API_KEY=
TRUSTED_HOSTS=staging.example.com
CORS_ORIGINS=https://staging.example.com

# Frontend required
NEXT_PUBLIC_API_BASE_URL=https://staging-api.example.com
NEXT_PUBLIC_APP_URL=https://staging.example.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace
